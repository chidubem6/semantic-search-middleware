APP_ENV=development
APP_NAME=Semantic Search Middleware
API_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/semantic_search
SOURCE_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/source_data
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
TOP_K=5
MIN_SIMILARITY_SCORE=0.30
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
