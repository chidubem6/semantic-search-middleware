APP_ENV=development
APP_NAME=Semantic Search Middleware
API_PREFIX=/api/v1
# Host port the Docker database is published on. Change if 5432 is already taken
# by another local Postgres (also update the ports in the two URLs below).
DB_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/semantic_search
SOURCE_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/source_data
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
TOP_K=5
MIN_SIMILARITY_SCORE=0.30
# What to index. Defaults live in config/settings.py; uncomment to override.
# INDEX_TABLE=support_tickets
# INDEX_PRIMARY_KEY=id
# INDEX_COLUMNS=["subject","body","product","status","priority"]
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
# Local models can be slow on first load; raise this if you see 503s.
LLM_TIMEOUT_SECONDS=60
